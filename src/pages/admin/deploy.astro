<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Deploy Settings | StaticPress Admin</title>
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
      else document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-gray-900 transition-colors">
    <div class="flex min-h-screen">
      <aside class="w-64 bg-gray-900 dark:bg-black text-white fixed h-full border-r border-gray-800">
        <div class="p-6 border-b border-gray-800"><h1 class="text-xl font-bold">StaticPress</h1><p class="text-xs text-gray-400 mt-1">Admin Panel</p></div>
        <nav class="p-4 space-y-2">
          <a href="/admin" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Dashboard</a>
          <div class="pt-4"><h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 mb-2">Content</h3>
            <a href="/admin/posts" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Posts</a>
            <a href="/admin/pages" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Pages</a>
          </div>
          <div class="pt-4"><h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 mb-2">Appearance</h3>
            <a href="/admin/theme" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Theme</a>
            <a href="/admin/layout" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Layout</a>
          </div>
          <div class="pt-4"><h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 mb-2">Publish</h3>
            <a href="/admin/build" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Build Site</a>
            <a href="/admin/deploy" class="block px-4 py-2 rounded bg-gray-800 transition">Deploy Settings</a>
          </div>
        </nav>
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-800">
          <button id="theme-toggle" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-400 hover:text-white transition w-full rounded hover:bg-gray-800">
            <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            <svg id="moon-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            <span id="theme-text">Light Mode</span>
          </button>
          <a href="/" target="_blank" class="block px-4 py-2 text-sm text-gray-400 hover:text-white transition mt-2">View Site →</a>
        </div>
      </aside>
      <main class="ml-64 flex-1 p-8">
        <div class="max-w-4xl">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Deploy Settings</h1>
          
          <!-- Site Configuration -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Site Configuration</h2>
            <p class="text-gray-600 dark:text-gray-300 text-sm mb-4">These settings are used for SEO, sitemap, and contact form.</p>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Site URL</label>
                <input type="url" id="site-url" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="https://example.com" />
                <p class="text-xs text-gray-500 mt-1">Your deployed site URL (no trailing slash)</p>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Formspree Form ID <a href="https://formspree.io" target="_blank" class="text-blue-500 text-xs">(Get Free Form →)</a></label>
                <input type="text" id="formspree-id" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="xyzabc123" />
                <p class="text-xs text-gray-500 mt-1">Required for contact form to work. Get a free form ID from formspree.io</p>
              </div>
              
              <button id="save-site-config" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Save Site Settings</button>
              <span id="site-config-status" class="ml-3 text-sm text-green-600 dark:text-green-400 hidden"></span>
            </div>
          </div>
          
          <!-- Cloudflare Configuration -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Cloudflare Pages Configuration</h2>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Project Name</label>
                <input type="text" id="cf-project" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="my-static-site" />
              </div>
               
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">API Token <a href="https://dash.cloudflare.com/profile/api-tokens" target="_blank" class="text-blue-500 text-xs">(Get Token →)</a></label>
                <input type="password" id="cf-token" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="toke****oken" />
                <p class="text-xs text-gray-500 mt-1">Token needs "Cloudflare Pages: Edit" permission</p>
              </div>
               
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Account ID</label>
                <input type="text" id="cf-account" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="Your Cloudflare Account ID" />
              </div>
               
              <button id="save-cf-config" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Save Cloudflare Settings</button>
            </div>
          </div>
          
          <!-- Deploy Section -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Deploy to Cloudflare Pages</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-4">Make sure you've built the site first from the Build Site page.</p>
            
            <div id="placeholder-warning" class="bg-yellow-50 dark:bg-yellow-900/30 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4 mb-4 hidden">
              <p class="text-yellow-700 dark:text-yellow-300 text-sm">⚠️ Site URL is still set to placeholder. Update it above before deploying.</p>
            </div>
            
            <button id="deploy-btn" class="px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
              Show Deploy Command
            </button>
            
            <div id="deploy-output" class="mt-4 bg-gray-900 rounded-lg p-4 hidden">
              <p class="text-yellow-400 text-sm mb-2">⚠️ Warning: Command contains your API token. Do not share this command.</p>
              <pre class="text-green-400 font-mono text-sm whitespace-pre-wrap mb-4" id="deploy-logs"></pre>
              <button id="copy-full-command" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition text-sm">
                Copy Full Command
              </button>
            </div>
          </div>
          
          <!-- Config File -->
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Save/Load Configuration</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm">Save all settings to a config file. File is automatically added to .gitignore.</p>
            <div class="flex gap-3">
              <button id="load-config" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">Load Config File</button>
              <button id="save-config" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">Save Config File</button>
            </div>
            <p id="config-status" class="text-sm text-gray-500 mt-2"></p>
          </div>
          
          <div class="bg-yellow-50 dark:bg-yellow-900/30 border border-yellow-200 dark:border-yellow-800 rounded-lg p-4">
            <h3 class="font-medium text-yellow-800 dark:text-yellow-200 mb-2">⚠️ Security Warning</h3>
            <p class="text-sm text-yellow-700 dark:text-yellow-300 mb-2">API tokens stored in browser localStorage are vulnerable to XSS attacks. For production use, keep your token in a config file instead.</p>
          </div>
        </div>
      </main>
    </div>
    
    <script is:inline>
      const SITE_URL_KEY = 'site_url';
      const FORMSPREE_KEY = 'formspree_id';
      const CF_PROJECT_KEY = 'cf_project';
      const CF_TOKEN_KEY = 'cf_token';
      const CF_ACCOUNT_KEY = 'cf_account';
      
      function maskToken(token) {
        if (!token || token.length < 8) return token;
        return token.slice(0, 4) + '****' + token.slice(-4);
      }
      
      function isPlaceholderUrl(url) {
        return !url || url === 'https://yoursite.com' || url.includes('localhost');
      }
      
      function showStatus(el, message, isError = false) {
        el.textContent = message;
        el.className = isError ? 'ml-3 text-sm text-red-600 dark:text-red-400' : 'ml-3 text-sm text-green-600 dark:text-green-400';
        el.classList.remove('hidden');
        setTimeout(() => el.classList.add('hidden'), 3000);
      }
      
      // Load values from localStorage
      const siteUrl = localStorage.getItem(SITE_URL_KEY) || '';
      const formspreeId = localStorage.getItem(FORMSPREE_KEY) || '';
      const cfProject = localStorage.getItem(CF_PROJECT_KEY) || '';
      const cfAccount = localStorage.getItem(CF_ACCOUNT_KEY) || '';
      const cfToken = localStorage.getItem(CF_TOKEN_KEY) || '';
      
      // Populate fields
      document.getElementById('site-url').value = siteUrl;
      document.getElementById('formspree-id').value = formspreeId;
      document.getElementById('cf-project').value = cfProject;
      document.getElementById('cf-account').value = cfAccount;
      if (cfToken) {
        document.getElementById('cf-token').value = cfToken;
        document.getElementById('cf-token').placeholder = maskToken(cfToken);
      }
      
      // Check for placeholder warning
      if (isPlaceholderUrl(siteUrl)) {
        document.getElementById('placeholder-warning').classList.remove('hidden');
      }
      
      // Save Site Config
      document.getElementById('save-site-config').addEventListener('click', () => {
        const url = document.getElementById('site-url').value.trim();
        const formId = document.getElementById('formspree-id').value.trim();
        
        if (!url) {
          alert('Site URL is required!');
          return;
        }
        
        localStorage.setItem(SITE_URL_KEY, url);
        localStorage.setItem(FORMSPREE_KEY, formId);
        
        const warningEl = document.getElementById('placeholder-warning');
        if (isPlaceholderUrl(url)) {
          warningEl.classList.remove('hidden');
        } else {
          warningEl.classList.add('hidden');
        }
        
        showStatus(document.getElementById('site-config-status'), 'Site settings saved!');
      });
      
      // Save Cloudflare Config
      document.getElementById('save-cf-config').addEventListener('click', () => {
        const project = document.getElementById('cf-project').value.trim();
        const token = document.getElementById('cf-token').value.trim();
        const account = document.getElementById('cf-account').value.trim();
        
        if (!project || !token || !account) {
          alert('Please fill in all Cloudflare fields!');
          return;
        }
        
        localStorage.setItem(CF_PROJECT_KEY, project);
        localStorage.setItem(CF_TOKEN_KEY, token);
        localStorage.setItem(CF_ACCOUNT_KEY, account);
        
        document.getElementById('cf-token').placeholder = maskToken(token);
        alert('Cloudflare settings saved!');
      });
      
      // Deploy button
      document.getElementById('deploy-btn').addEventListener('click', () => {
        const project = localStorage.getItem(CF_PROJECT_KEY);
        const token = localStorage.getItem(CF_TOKEN_KEY);
        const account = localStorage.getItem(CF_ACCOUNT_KEY);
        
        if (!project || !token || !account) {
          alert('Please save your Cloudflare settings first!');
          return;
        }
        
        const output = document.getElementById('deploy-output');
        const logs = document.getElementById('deploy-logs');
        
        output.classList.remove('hidden');
        
        const maskedCommand = `CF_API_TOKEN=${maskToken(token)} CF_ACCOUNT_ID=${account} bunx wrangler pages deploy dist --project-name=${project}`;
        
        logs.innerHTML = `<p class="text-yellow-400 text-xs mb-2">⚠️ Token will be visible in the copied command. Keep it secure!</p><code class="text-green-400">${maskedCommand.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code>`;
      });
      
      // Copy command
      document.getElementById('copy-full-command')?.addEventListener('click', async () => {
        const project = localStorage.getItem(CF_PROJECT_KEY);
        const token = localStorage.getItem(CF_TOKEN_KEY);
        const account = localStorage.getItem(CF_ACCOUNT_KEY);
        
        if (!project || !token || !account) {
          alert('Please save your Cloudflare settings first!');
          return;
        }
        
        const fullCommand = `CF_API_TOKEN=${token} CF_ACCOUNT_ID=${account} bunx wrangler pages deploy dist --project-name=${project}`;
        
        try {
          await navigator.clipboard.writeText(fullCommand);
          const btn = document.getElementById('copy-full-command');
          const original = btn.textContent;
          btn.textContent = 'Copied!';
          btn.classList.add('bg-green-700');
          setTimeout(() => {
            btn.textContent = original;
            btn.classList.remove('bg-green-700');
          }, 2000);
        } catch (err) {
          alert('Failed to copy. Please select and copy manually.');
        }
      });
      
      // Save config file
      document.getElementById('save-config').addEventListener('click', () => {
        const siteUrl = localStorage.getItem(SITE_URL_KEY) || '';
        const formspreeId = localStorage.getItem(FORMSPREE_KEY) || '';
        const cfProject = localStorage.getItem(CF_PROJECT_KEY) || '';
        const cfToken = localStorage.getItem(CF_TOKEN_KEY) || '';
        const cfAccount = localStorage.getItem(CF_ACCOUNT_KEY) || '';
        
        const config = {
          siteUrl,
          formspreeId,
          cloudflare: {
            project: cfProject,
            token: cfToken,
            account: cfAccount
          }
        };
        
        const blob = new Blob([JSON.stringify(config, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'staticpress-config.json';
        a.click();
        URL.revokeObjectURL(url);
        
        document.getElementById('config-status').textContent = 'Config saved! WARNING: Contains API token - keep file secure.';
      });
      
      // Load config file
      document.getElementById('load-config').addEventListener('click', async () => {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        input.onchange = async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          
          const text = await file.text();
          try {
            const config = JSON.parse(text);
            
            // Site settings
            if (config.siteUrl) {
              localStorage.setItem(SITE_URL_KEY, config.siteUrl);
              document.getElementById('site-url').value = config.siteUrl;
            }
            if (config.formspreeId) {
              localStorage.setItem(FORMSPREE_KEY, config.formspreeId);
              document.getElementById('formspree-id').value = config.formspreeId;
            }
            
            // Cloudflare settings
            if (config.cloudflare) {
              if (config.cloudflare.project) {
                localStorage.setItem(CF_PROJECT_KEY, config.cloudflare.project);
                document.getElementById('cf-project').value = config.cloudflare.project;
              }
              if (config.cloudflare.account) {
                localStorage.setItem(CF_ACCOUNT_KEY, config.cloudflare.account);
                document.getElementById('cf-account').value = config.cloudflare.account;
              }
              if (config.cloudflare.token) {
                localStorage.setItem(CF_TOKEN_KEY, config.cloudflare.token);
                document.getElementById('cf-token').value = config.cloudflare.token;
                document.getElementById('cf-token').placeholder = maskToken(config.cloudflare.token);
              }
            }
            
            // Update warning
            const warningEl = document.getElementById('placeholder-warning');
            if (isPlaceholderUrl(config.siteUrl)) {
              warningEl.classList.remove('hidden');
            } else {
              warningEl.classList.add('hidden');
            }
            
            document.getElementById('config-status').textContent = 'Config loaded successfully!';
          } catch (err) {
            alert('Invalid config file');
          }
        };
        input.click();
      });
    </script>
    
    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('sun-icon'), moonIcon = document.getElementById('moon-icon'), themeText = document.getElementById('theme-text');
      function updateIcons() {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) { sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden'); themeText.textContent = 'Switch to Light'; } 
        else { sunIcon.classList.add('hidden'); moonIcon.classList.remove('hidden'); themeText.textContent = 'Switch to Dark'; }
      }
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) { document.documentElement.classList.remove('dark'); localStorage.setItem('theme', 'light'); } 
        else { document.documentElement.classList.add('dark'); localStorage.setItem('theme', 'dark'); }
        updateIcons();
      });
      updateIcons();
    </script>
  </body>
</html>