---
import '../../styles/global.css';
const pageTitle = "Deploy Settings";
---
<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle} | StaticPress Admin</title>
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
      else document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-gray-900 transition-colors">
    <div class="flex min-h-screen">
      <aside class="w-64 bg-gray-900 dark:bg-black text-white fixed h-full border-r border-gray-800">
        <div class="p-6 border-b border-gray-800"><h1 class="text-xl font-bold">StaticPress</h1><p class="text-xs text-gray-400 mt-1">Admin Panel</p></div>
        <nav class="p-4 space-y-2">
          <a href="/admin" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Dashboard</a>
          <div class="pt-4"><h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 mb-2">Content</h3>
            <a href="/admin/posts" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Posts</a>
            <a href="/admin/pages" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Pages</a>
          </div>
          <div class="pt-4"><h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 mb-2">Appearance</h3>
            <a href="/admin/theme" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Theme</a>
            <a href="/admin/layout" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Layout</a>
          </div>
          <div class="pt-4"><h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wider px-4 mb-2">Publish</h3>
            <a href="/admin/build" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Build Site</a>
            <a href="/admin/deploy" class="block px-4 py-2 rounded hover:bg-gray-800 transition">Deploy Settings</a>
          </div>
        </nav>
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-800">
          <button id="theme-toggle" class="flex items-center gap-2 px-4 py-2 text-sm text-gray-400 hover:text-white transition w-full rounded hover:bg-gray-800">
            <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
            <svg id="moon-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
            <span id="theme-text">Light Mode</span>
          </button>
          <a href="/" target="_blank" class="block px-4 py-2 text-sm text-gray-400 hover:text-white transition mt-2">View Site →</a>
        </div>
      </aside>
      <main class="ml-64 flex-1 p-8">
        <div class="max-w-4xl">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Deploy Settings</h1>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Cloudflare Configuration</h2>
            
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Project Name</label>
                <input type="text" id="cf-project" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="my-static-site" />
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">API Token</label>
                <input type="password" id="cf-token" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="toke****oken" />
                <p class="text-xs text-gray-500 mt-1">Token needs "Cloudflare Pages: Edit" permission</p>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Account ID</label>
                <input type="text" id="cf-account" class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white rounded-lg" placeholder="Your Cloudflare Account ID" />
              </div>
              
              <button id="save-config" class="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Save Settings</button>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Deploy to Cloudflare</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-4">Make sure you've built the site first from Build Site page.</p>
            
            <button id="deploy-btn" class="px-6 py-3 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
              Deploy Now
            </button>
            
            <div id="deploy-output" class="mt-4 bg-gray-900 rounded-lg p-4 hidden">
              <pre class="text-green-400 font-mono text-sm whitespace-pre-wrap" id="deploy-logs"></pre>
            </div>
          </div>
          
          <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Local Config File</h2>
            <p class="text-gray-600 dark:text-gray-300 mb-4 text-sm">Save your config to a local file instead of browser storage. File is automatically added to .gitignore.</p>
            <div class="flex gap-3">
              <button id="load-config" class="px-4 py-2 bg-gray-600 text-white rounded-lg hover:bg-gray-700 transition">Load from File</button>
              <button id="save-config-file" class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition">Save to File</button>
            </div>
            <p id="config-status" class="text-sm text-gray-500 mt-2"></p>
          </div>
        </div>
      </main>
    </div>
    
    <script is:inline>
      function maskToken(token) {
        if (!token || token.length < 8) return token;
        return token.slice(0, 4) + '****' + token.slice(-4);
      }
      
      let storedToken = localStorage.getItem('cf_token');
      if (storedToken) {
        document.getElementById('cf-token').placeholder = maskToken(storedToken);
      }
      
      const savedProject = localStorage.getItem('cf_project');
      const savedAccount = localStorage.getItem('cf_account');
      if (savedProject) document.getElementById('cf-project').value = savedProject;
      if (savedAccount) document.getElementById('cf-account').value = savedAccount;
      
      document.getElementById('save-config').addEventListener('click', () => {
        const project = document.getElementById('cf-project').value;
        const token = document.getElementById('cf-token').value || storedToken;
        const account = document.getElementById('cf-account').value;
        
        if (!project || !token || !account) {
          alert('Please fill in all fields!');
          return;
        }
        
        localStorage.setItem('cf_project', project);
        localStorage.setItem('cf_token', token);
        localStorage.setItem('cf_account', account);
        storedToken = token;
        document.getElementById('cf-token').placeholder = maskToken(token);
        alert('Settings saved to browser!');
      });
      
      document.getElementById('save-config-file').addEventListener('click', async () => {
        const project = document.getElementById('cf-project').value;
        const token = document.getElementById('cf-token').value || storedToken;
        const account = document.getElementById('cf-account').value;
        
        if (!project || !account) {
          alert('Please fill in Project Name and Account ID first!');
          return;
        }
        
        const config = { project, account };
        const blob = new Blob([JSON.stringify(config, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'staticpress-config.json';
        a.click();
        URL.revokeObjectURL(url);
        
        document.getElementById('config-status').textContent = 'Config downloaded! Move this file to your project root and rename to .staticpress.json';
      });
      
      document.getElementById('load-config').addEventListener('click', async () => {
        const input = document.createElement('input');
        input.type = 'file';
        input.accept = '.json';
        input.onchange = async (e) => {
          const file = e.target.files[0];
          if (!file) return;
          
          const text = await file.text();
          try {
            const config = JSON.parse(text);
            if (config.project) document.getElementById('cf-project').value = config.project;
            if (config.account) document.getElementById('cf-account').value = config.account;
            
            localStorage.setItem('cf_project', config.project || '');
            localStorage.setItem('cf_account', config.account || '');
            
            document.getElementById('config-status').textContent = 'Config loaded! Token still needed - enter it below.';
          } catch (err) {
            alert('Invalid config file');
          }
        };
        input.click();
      });
      
      document.getElementById('deploy-btn').addEventListener('click', async () => {
        const project = localStorage.getItem('cf_project');
        const token = localStorage.getItem('cf_token');
        const account = localStorage.getItem('cf_account');
        
        if (!project || !token || !account) {
          alert('Please save your Cloudflare settings first!');
          return;
        }
        
        const btn = document.getElementById('deploy-btn');
        const output = document.getElementById('deploy-output');
        const logs = document.getElementById('deploy-logs');
        
        btn.disabled = true;
        btn.textContent = 'Preparing...';
        output.classList.remove('hidden');
        logs.textContent = 'Deploying to Cloudflare Pages...\n\n';
        logs.textContent += 'Run this command in your terminal:\n\n';
        logs.textContent += `  CF_API_TOKEN=${token} \\\n  CF_ACCOUNT_ID=${account} \\\n  bunx wrangler pages deploy dist --project-name=${project}\n\n`;
        logs.textContent += 'Make sure you have run "bun run build" first!';
        
        btn.disabled = false;
        btn.textContent = 'Show Deploy Command';
      });
    </script>
    
    <script is:inline>
      const toggle = document.getElementById('theme-toggle');
      const sunIcon = document.getElementById('sun-icon'), moonIcon = document.getElementById('moon-icon'), themeText = document.getElementById('theme-text');
      function updateIcons() {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) { sunIcon.classList.remove('hidden'); moonIcon.classList.add('hidden'); themeText.textContent = 'Light Mode'; } 
        else { sunIcon.classList.add('hidden'); moonIcon.classList.remove('hidden'); themeText.textContent = 'Dark Mode'; }
      }
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.contains('dark');
        if (isDark) { document.documentElement.classList.remove('dark'); localStorage.setItem('theme', 'light'); } 
        else { document.documentElement.classList.add('dark'); localStorage.setItem('theme', 'dark'); }
        updateIcons();
      });
      updateIcons();
    </script>
  </body>
</html>
