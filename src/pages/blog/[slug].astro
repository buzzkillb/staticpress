---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter(post => post.data.published)
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} | StaticPress</title>
    <meta name="description" content={post.data.excerpt || post.data.title} />
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
      else document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-gray-900 transition-colors">
    <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-gray-900 dark:text-white">StaticPress</a>
        <nav class="flex gap-4">
          <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">Home</a>
          <a href="/blog" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">Blog</a>
        </nav>
      </div>
    </header>
    
    <main class="max-w-4xl mx-auto px-4 py-8">
      <article class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-8">
        <header class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-700">
          <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">{post.data.title}</h1>
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            {post.data.published && (
              <span class="px-2 py-1 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 rounded">Published</span>
            )}
          </div>
        </header>
        
        <div class="prose prose-gray dark:prose-invert max-w-none">
          <Content />
        </div>
      </article>
      
      <div class="mt-8">
        <a href="/blog" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:underline">
          ← Back to Blog
        </a>
      </div>
    </main>
    
    <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-12">
      <div class="max-w-4xl mx-auto py-6 text-center text-gray-600 dark:text-gray-400">
        Built with StaticPress
      </div>
    </footer>
  </body>
</html>
