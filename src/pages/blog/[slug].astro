---
import { getCollection, render } from 'astro:content';
import '../../styles/global.css';
import { SITE_URL, SITE_NAME, AUTHOR } from '../../lib/config';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts
    .filter(post => post.data.published)
    .map(post => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const { title, excerpt, date } = post.data;

const siteUrl = SITE_URL;
const canonicalUrl = `${siteUrl}/blog/${post.id}/`;
const ogImage = `${siteUrl}/og-image.png`; // Optional: generate OG images
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary SEO -->
    <title>{title} | {SITE_NAME}</title>
    <meta name="description" content={excerpt || title} />
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={excerpt || title} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="article:published_time" content={date?.toISOString()} />
    <meta property="article:modified_time" content={date?.toISOString()} />
    <meta property="article:author" content={AUTHOR} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={excerpt || title} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    
    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    
    <!-- Theme -->
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
      else document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="bg-gray-50 dark:bg-gray-900 transition-colors">
    <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-gray-900 dark:text-white">{SITE_NAME}</a>
        <nav class="flex gap-4">
          <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">Home</a>
          <a href="/blog" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">Blog</a>
        </nav>
      </div>
    </header>
    
    <main class="max-w-4xl mx-auto px-4 py-8">
      <article class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-8">
        <header class="mb-8 pb-8 border-b border-gray-200 dark:border-gray-700">
          <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">{title}</h1>
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <time datetime={date?.toISOString()}>
              {date?.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <span class="px-2 py-1 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 rounded">Published</span>
          </div>
        </header>
        
        <div class="prose prose-gray dark:prose-invert max-w-none">
          <Content />
        </div>
      </article>
      
      <nav class="mt-8 flex justify-between items-center">
        <a href="/blog" class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 hover:underline">
          ← Back to Blog
        </a>
        <a href="/" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white">Home</a>
      </nav>
    </main>
    
    <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-12">
      <div class="max-w-4xl mx-auto py-6 text-center text-gray-600 dark:text-gray-400">
        <p>Built with <a href="https://github.com/buzzkillb/staticpress" class="text-blue-600 hover:underline">{SITE_NAME}</a></p>
      </div>
    </footer>
  </body>
</html>
