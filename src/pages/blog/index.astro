---
import '../../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog | StaticPress</title>
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
      else document.documentElement.classList.add('dark');
    </script>
  </head>
  <body class="bg-gray-100 dark:bg-gray-900 transition-colors">
    <header class="bg-white dark:bg-gray-800 border-b border-gray-200 dark:border-gray-700">
      <div class="max-w-4xl mx-auto px-4 py-4 flex justify-between items-center">
        <a href="/" class="text-xl font-bold text-gray-900 dark:text-white">StaticPress</a>
        <nav class="flex gap-4">
          <a href="/" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">Home</a>
          <a href="/blog" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">Blog</a>
          <a href="/about" class="text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white">About</a>
        </nav>
      </div>
    </header>
    
    <main class="max-w-4xl mx-auto px-4 py-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">Blog</h1>
      
      <div class="space-y-6">
        <article class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 p-6">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-2">
            <a href="/blog/welcome" class="hover:text-blue-600 dark:hover:text-blue-400">Welcome to StaticPress</a>
          </h2>
          <p class="text-gray-600 dark:text-gray-300 mb-4">Your first blog post with StaticPress</p>
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <span>2026-03-15</span>
            <span class="px-2 py-1 bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-300 rounded">Published</span>
          </div>
        </article>
      </div>
    </main>
    
    <footer class="bg-white dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700 mt-12">
      <div class="max-w-4xl mx-auto px-4 py-6 text-center text-gray-600 dark:text-gray-400">
        Built with StaticPress
      </div>
    </footer>
  </body>
</html>
