---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = 'A static site built with StaticPress', image } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="StaticPress" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
    
    <!-- Theme and Custom CSS -->
    <script is:inline>
      (function() {
        // Apply theme
        if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
        else document.documentElement.classList.add('dark');
        
        // Apply custom theme CSS (sanitized to prevent XSS)
        const themeCss = localStorage.getItem('theme_css');
        if (themeCss) {
          // Escape patterns that could escape the style tag
          const sanitized = themeCss
            .replace(/<\//gi, '<\\/')
            .replace(/<\/style/gi, '<\\/style')
            .replace(/<\/script/gi, '<\\/script');
          const style = document.createElement('style');
          style.textContent = sanitized;
          document.head.appendChild(style);
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
