---
import { SITE_NAME } from '../lib/config';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = `A static site built with ${SITE_NAME}`, image } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {image && <meta property="og:image" content={image} />}
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {image && <meta name="twitter:image" content={image} />}
    
    <!-- Theme and Custom CSS -->
    <script is:inline>
      (function() {
        // Apply theme
        if (localStorage.getItem('theme') === 'light') document.documentElement.classList.remove('dark');
        else document.documentElement.classList.add('dark');
        
        // Apply custom theme CSS - only allow CSS custom properties for safety
        const themeCss = localStorage.getItem('theme_css');
        if (themeCss) {
          // Whitelist of safe CSS custom property names
          const allowedProps = new Set([
            '--color-primary', '--color-background', '--color-text', '--color-secondary',
            '--color-accent', '--color-border', '--color-heading', '--color-link',
            '--color-link-hover', '--color-code-background', '--color-code-text',
            '--font-family-base', '--font-family-heading', '--font-size-base',
            '--font-size-sm', '--font-size-lg', '--font-size-xl', '--font-size-2xl',
            '--font-size-3xl', '--line-height-base', '--line-height-heading',
            '--spacing-base', '--spacing-sm', '--spacing-md', '--spacing-lg',
            '--spacing-xl', '--spacing-2xl', '--border-radius', '--border-radius-sm',
            '--border-radius-md', '--border-radius-lg', '--border-radius-full',
            '--shadow-sm', '--shadow-md', '--shadow-lg', '--shadow-xl',
            '--transition-fast', '--transition-normal', '--transition-slow'
          ]);
          
          // Strict value patterns - no semicolons or special characters allowed
          const safeValuePatterns = [
            /^#[0-9a-fA-F]{3,8}$/,
            /^rgb\(\s*(\d{1,3}\s*,\s*){2}\d{1,3}\s*\)$/,
            /^rgba\(\s*(\d{1,3}\s*,\s*){3}(\d*\.\d+|\d)\s*\)$/,
            /^hsl\(\s*(\d{1,3}\s*,\s*\d{1,3}%\s*,\s*\d{1,3}%)\s*\)$/,
            /^hsla\(\s*(\d{1,3}\s*,\s*\d{1,3}%\s*,\s*\d{1,3}%\s*,\s*(\d*\.\d+|\d)\s*\)$/,
            /^(\d+\.)?\d+(px|em|rem|%|vh|vw|pt|ex|ch|mm|cm)?$/,
            /^(inherit|initial|unset|none|transparent|auto)$/
          ];
          
          const lines = themeCss.split(';');
          const validVars = [];
          for (const line of lines) {
            const trimmed = line.trim();
            if (!trimmed) continue;
            
            // Parse property name (between -- and :)
            const colonIndex = trimmed.indexOf(':');
            if (colonIndex === -1) continue;
            
            const propName = trimmed.substring(0, colonIndex);
            const propValue = trimmed.substring(colonIndex + 1).trim();
            
            // Check if property is whitelisted
            if (!allowedProps.has(propName)) continue;
            
            // Check if value matches safe patterns
            let valueSafe = false;
            for (const pattern of safeValuePatterns) {
              if (pattern.test(propValue)) {
                valueSafe = true;
                break;
              }
            }
            
            if (valueSafe) {
              validVars.push(`${propName}: ${propValue}`);
            }
          }
          
          if (validVars.length > 0) {
            const style = document.createElement('style');
            style.textContent = ':root { ' + validVars.join('; ') + ' }';
            document.head.appendChild(style);
          }
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
